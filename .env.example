# ─────────────────────────────────────────────
# ClickUp Configuration
# ─────────────────────────────────────────────

# Your ClickUp personal API token
# Find at: ClickUp → Settings → Apps → API Token
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your ClickUp Team (Workspace) ID — required for the Docs API
# Find at: ClickUp → Settings → look at URL: app.clickup.com/{TEAM_ID}/...
CLICKUP_TEAM_ID=1234567

# Webhook signing secret (auto-populated when you run: npm run setup-webhook)
CLICKUP_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# DocuSeal Configuration
# ─────────────────────────────────────────────

# Your DocuSeal API token
# Find at: DocuSeal → Settings → API
DOCUSEAL_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# App Configuration
# ─────────────────────────────────────────────

# The public URL where this app is hosted (no trailing slash)
# Used for webhook registration. For local dev, use your ngrok URL.
# Examples: https://abc123.ngrok-free.app, https://your-app.railway.app
SERVER_URL=https://your-app.example.com

# Port to listen on (default: 3000)
PORT=3000

# ─────────────────────────────────────────────
# REQUIRED CLICKUP CUSTOM FIELDS ON YOUR TASKS
# ─────────────────────────────────────────────
#
# Your Agreements list in ClickUp must have these custom fields:
#
#   1. Agreement Status       — Dropdown
#      Options: Draft, Sent, Signed, Expired, Declined
#
#   2. Agreement Doc URL      — URL or Short Text
#      Holds the link to the ClickUp Doc that IS the agreement.
#      Example value: https://app.clickup.com/9012345/v/dc/abc123-456
#
#   3. Client Full Name       — Short Text
#   4. Client Email           — Email
#   5. Client Phone Number    — Phone
#   6. Client Mailing Address — Short Text
#   7. Company Name           — Short Text
#   8. Effective Date         — Date
#   9. Expiration Date        — Date
#
#   Optional:
#   10. Secondary Signer Name  — Short Text
#   11. Secondary Signer Email — Email
#
# The workflow:
#   - User fills in all fields and pastes the ClickUp Doc link
#   - User changes Agreement Status → Sent
#   - This app detects the change, fetches the Doc, sends via DocuSeal
#   - When signed, this app updates Agreement Status → Signed and
#     attaches the signed PDF back to the task
#
